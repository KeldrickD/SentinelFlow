# AI Gateway (x402 seller) - copy to .env
# Wallet that receives USDC (Base Sepolia for testnet)
PAY_TO_ADDRESS=0xYourAddress
# Price per /analyze call (USD, numeric only — no $)
X402_PRICE=0.01
# Testnet facilitator (use CDP for mainnet)
X402_FACILITATOR_URL=https://x402.org/facilitator
# OpenAI for AI inference
OPENAI_API_KEY=your_openai_key
PORT=8080
AI_MODEL=gpt-4o-mini
